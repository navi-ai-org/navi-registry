{
  "id": "llamacpp",
  "label": "Llama.cpp",
  "description": "Self-hosted GGUF inference",
  "kind": "openai-chat-completions",
  "api_key_env": "LLAMACPP_API_KEY",
  "base_url": "http://localhost:8080/v1",
  "models": [
    { "name": "local-model", "task_size": "large", "context_window_tokens": 128000 },
    { "name": "qwen2.5-coder", "task_size": "large", "context_window_tokens": 128000 },
    { "name": "deepseek-coder", "task_size": "large", "context_window_tokens": 1000000 },
    { "name": "starcoder2", "task_size": "small", "context_window_tokens": 16000 },
    { "name": "granite-code", "task_size": "small", "context_window_tokens": 128000 },
    { "name": "llama3", "task_size": "large", "context_window_tokens": 128000 },
    { "name": "mistral", "task_size": "small", "context_window_tokens": 32000 },
    { "name": "tinyllama", "task_size": "small", "context_window_tokens": 2048 }
  ]
}
