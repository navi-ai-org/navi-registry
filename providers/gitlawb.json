{
  "id": "gitlawb",
  "label": "Gitlawb",
  "description": "Decentralized code collaboration platform gateway with Xiaomi MiMo and Google Gemini models.",
  "kind": "openai-chat-completions",
  "api_key_env": "GITLAWB_API_KEY",
  "base_url": "https://opengateway.gitlawb.com/v1",
  "defaults": {
    "attachments": {
      "images": false,
      "audio": false,
      "video": false,
      "documents": false
    }
  },
